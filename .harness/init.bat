@echo off
REM Baseline verification for the coherence-to-internal_consistency rename.
REM Generated by the initializer agent -- no dev server needed for this doc-only patch.

set "PROJECT_ROOT=%~dp0.."
set MISSING=0
set FOUND=0

echo Verifying target files exist...

for %%f in (
  "plugins\harness\skills\harness\SKILL.md"
  "plugins\harness\skills\harness\references\patterns.md"
  "plugins\harness\agents\generator.md"
  "plugins\harness\skills\harness\roles\generator.md"
  "plugins\harness\agents\evaluator.md"
  "plugins\harness\skills\harness\roles\evaluator.md"
) do (
  if exist "%PROJECT_ROOT%\%%~f" (
    echo OK   -- %%~f
  ) else (
    echo MISSING -- %%~f
    set /a MISSING+=1
  )
)

echo.

if %MISSING% GTR 0 (
  echo FAIL -- %MISSING% target file(s) missing
  exit /b 1
)

echo All 6 target files exist.
echo.
echo Checking for coherence in authenticity gate contexts...

for %%f in (
  "plugins\harness\skills\harness\SKILL.md"
  "plugins\harness\skills\harness\references\patterns.md"
  "plugins\harness\agents\generator.md"
  "plugins\harness\skills\harness\roles\generator.md"
  "plugins\harness\agents\evaluator.md"
  "plugins\harness\skills\harness\roles\evaluator.md"
) do (
  findstr /C:"coherence" "%PROJECT_ROOT%\%%~f" >nul 2>&1
  if not errorlevel 1 set /a FOUND+=1
)

echo Files containing coherence: %FOUND%/6
echo.
echo Baseline verification complete.
