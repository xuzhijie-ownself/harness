@echo off
REM Verify baseline structure for harness two-plugin refactor.
REM Generated by the initializer agent — no dev server needed for this refactoring project.

set "ROOT=%~dp0.."
set "CORE_SKILLS=%ROOT%\plugins\harness\skills"
set FAIL=0

echo === Harness v2.0.0 Refactor — Baseline Smoke Test ===

REM 1. Verify core skill exists
if exist "%CORE_SKILLS%\harness\SKILL.md" (
  echo OK — core skill exists
) else (
  echo FAIL — core skill not found
  set /a FAIL+=1
)

REM 2. Verify 5 domain skills exist (pre-refactor or post-refactor location)
for %%S in (harness-sdlc harness-ea harness-ba harness-sa harness-ops) do (
  if exist "%CORE_SKILLS%\%%S\SKILL.md" (
    echo OK — domain skill %%S exists in core plugin (pre-refactor)
  ) else if exist "%ROOT%\plugins\harness-sdlc-suite\skills\%%S\SKILL.md" (
    echo OK — domain skill %%S exists in sdlc-suite plugin (post-refactor)
  ) else (
    echo FAIL — domain skill %%S not found in either location
    set /a FAIL+=1
  )
)

REM 3. Verify manifests exist
if exist "%ROOT%\.claude-plugin\marketplace.json" (
  echo OK — marketplace.json exists
) else (
  echo FAIL — marketplace.json not found
  set /a FAIL+=1
)

if exist "%ROOT%\.codex-plugin\plugin.json" (
  echo OK — codex plugin.json exists
) else (
  echo FAIL — codex plugin.json not found
  set /a FAIL+=1
)

REM 4. Verify install scripts exist
if exist "%ROOT%\install.sh" (
  echo OK — install.sh exists
) else (
  echo FAIL — install.sh not found
  set /a FAIL+=1
)

if exist "%ROOT%\install.bat" (
  echo OK — install.bat exists
) else (
  echo FAIL — install.bat not found
  set /a FAIL+=1
)

REM 5. Verify README exists
if exist "%ROOT%\README.md" (
  echo OK — README.md exists
) else (
  echo FAIL — README.md not found
  set /a FAIL+=1
)

echo.
if %FAIL% GTR 0 (
  echo FAIL — %FAIL% check(s) failed
  exit /b 1
)

echo OK — baseline smoke test passed
